<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="SportLink.Mobile.Pages.Polls.CreatePollPage"
             BackgroundColor="#F7F8FC">

    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="20">

            <Label Text="Create Poll"
                   FontSize="28"
                   FontAttributes="Bold"
                   TextColor="Black" />

            <Entry x:Name="QuestionEntry"
                   Placeholder="Poll question"
                   TextColor="Black" />

            <Entry x:Name="Option1Entry"
                   Placeholder="Option 1"
                   TextColor="Black" />

            <Entry x:Name="Option2Entry"
                   Placeholder="Option 2"
                   TextColor="Black" />

            <Entry x:Name="Option3Entry"
                   Placeholder="Option 3"
                   TextColor="Black" />

            <Button Text="Save Poll"
                    Clicked="OnSavePollClicked" />

        </VerticalStackLayout>
    </ScrollView>

</ContentPage>