<?xml version="1.0" encoding="UTF-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="SportLink.Mobile.Pages.SOS.SOSPage"
             BackgroundColor="#F7F8FC">

    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="20">

            <!-- Safety Status Card -->
            <Frame BackgroundColor="#E6ECF5"
                   CornerRadius="18"
                   Padding="16"
                   HasShadow="True">

                <VerticalStackLayout Spacing="4">
                    <Label Text="Safety Status"
                           FontAttributes="Bold"
                           FontSize="16"
                           TextColor="#333"/>

                    <!-- ✅ FIXED NAME -->
                    <Label x:Name="StatusLabel"
                           Text="No active session"
                           FontSize="12"
                           TextColor="#777"/>

                    <Label x:Name="TimerLabel"
                           Text="00:00:00"
                           FontSize="14"
                           TextColor="Red"
                           IsVisible="False"/>
                </VerticalStackLayout>
            </Frame>

            <!-- SOS Button -->
            <VerticalStackLayout HorizontalOptions="Center" Spacing="10">

                <Grid WidthRequest="120"
          HeightRequest="120">

                    <!-- DESIGN (unchanged look) -->
                    <Frame BackgroundColor="#FAD4D4"
               CornerRadius="100"
               HasShadow="True"
               InputTransparent="True"/>

                    <!-- TEXT (visible SOS) -->
                    <Label Text="SOS"
               HorizontalOptions="Center"
               VerticalOptions="Center"
               FontSize="18"
               TextColor="#D64545"
               FontAttributes="Bold"
               InputTransparent="True"/>

                    <!-- CLICK LAYER -->
                    <Button BackgroundColor="Transparent"
                CornerRadius="100"
                Clicked="OnSOSTapped"/>

                </Grid>

                <Label x:Name="InstructionLabel"
           Text="Tap to activate SOS"
           FontSize="12"
           TextColor="#777"
           HorizontalOptions="Center"/>

            </VerticalStackLayout>
            <!-- Divider -->
            <BoxView HeightRequest="1" BackgroundColor="#DDD"/>

            <!-- Contacts Title -->
            <Label Text="Emergency Contacts"
                   FontSize="18"
                   FontAttributes="Bold"
                   TextColor="#333"/>

            <!-- Contacts List -->
            <CollectionView x:Name="ContactsList"
                            ItemsLayout="VerticalList">

                <CollectionView.ItemTemplate>
                    <DataTemplate>
                        <Frame BackgroundColor="White"
                               CornerRadius="18"
                               Padding="14"
                               Margin="0,5"
                               HasShadow="True">

                            <VerticalStackLayout>
                                <Label Text="{Binding Name}"
                                       FontAttributes="Bold"
                                       TextColor="#333"/>

                                <Label Text="{Binding Phone}"
                                       FontSize="12"
                                       TextColor="#777"/>
                            </VerticalStackLayout>
                        </Frame>
                    </DataTemplate>
                </CollectionView.ItemTemplate>

            </CollectionView>

            <!-- Add Button -->
            <Button Text="Add emergency contact"
                    BackgroundColor="#DFF0DF"
                    TextColor="#333"
                    CornerRadius="20"
                    HeightRequest="45"
                    HorizontalOptions="Center"
                    WidthRequest="220"
                    Clicked="OnAddContactClicked"/>

        </VerticalStackLayout>
    </ScrollView>

</ContentPage>