<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="SportLink.Mobile.Pages.SOS.AddContactPage"
             BackgroundColor="#F7F8FC">

    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="18">

            <Label Text="Add Emergency Contact"
                   FontSize="28"
                   FontAttributes="Bold"
                   TextColor="#111" />

            <!-- Name -->
            <Frame CornerRadius="14"
                   BackgroundColor="White"
                   HasShadow="True"
                   Padding="12">

                <Entry x:Name="NameEntry"
                       Placeholder="Enter full name"
                       PlaceholderColor="#999999"
                       TextColor="#111"
                       FontSize="15" />
            </Frame>

            <!-- Phone -->
            <Frame CornerRadius="14"
                   BackgroundColor="White"
                   HasShadow="True"
                   Padding="12">

                <Entry x:Name="PhoneEntry"
                       Placeholder="Enter phone number"
                       PlaceholderColor="#999999"
                       Keyboard="Telephone"
                       TextColor="#111"
                       FontSize="15" />
            </Frame>

            <!-- Save button -->
            <Button Text="Save Contact"
                    Clicked="OnSaveContactClicked"
                    HeightRequest="50"
                    CornerRadius="16"
                    FontAttributes="Bold"
                    BackgroundColor="#6C5CE7"
                    TextColor="White"
                    Margin="0,10,0,0" />

        </VerticalStackLayout>
    </ScrollView>

</ContentPage>