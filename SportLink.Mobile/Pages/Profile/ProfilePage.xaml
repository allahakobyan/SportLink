<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="SportLink.Mobile.Pages.Profile.ProfilePage"
             BackgroundColor="#F7F8FC"
             Title="Profile">

    <Grid>
        <VerticalStackLayout Spacing="0">

            <BoxView HeightRequest="18" Color="Transparent" />

            <Frame Margin="14,0,14,0"
                   Padding="0"
                   CornerRadius="24"
                   BackgroundColor="White"
                   HasShadow="True">

                <VerticalStackLayout Spacing="0">

                    <Grid HeightRequest="110" BackgroundColor="#DCE4F5">

                        <BoxView Color="#DCE4F5" />

                        <Frame WidthRequest="110"
                               HeightRequest="110"
                               CornerRadius="55"
                               Padding="0"
                               IsClippedToBounds="True"
                               HorizontalOptions="Center"
                               VerticalOptions="End"
                               Margin="0,0,0,-55"
                               HasShadow="False"
                               BackgroundColor="White">

                            <Image x:Name="ProfileImage"
                                   Source="https://via.placeholder.com/150"
                                   Aspect="AspectFill">
                                <Image.GestureRecognizers>
                                    <TapGestureRecognizer Tapped="OnChangeImageTapped"/>
                                </Image.GestureRecognizers>
                            </Image>

                        </Frame>
                    </Grid>

                    <BoxView HeightRequest="60" Color="Transparent" />

                    <VerticalStackLayout Spacing="2"
                                         HorizontalOptions="Center"
                                         Margin="0,0,0,14">
                        <Label x:Name="FullNameLabel"
                               FontSize="18"
                               FontAttributes="Bold"
                               TextColor="#111"
                               HorizontalOptions="Center"
                               HorizontalTextAlignment="Center" />
                        <Label x:Name="UsernameLabel"
                               FontSize="14"
                               TextColor="#777"
                               HorizontalOptions="Center"
                               HorizontalTextAlignment="Center" />
                    </VerticalStackLayout>

                    <BoxView HeightRequest="1" Color="#E6E6E6" />

                    <Grid ColumnDefinitions="*,*,*"
                          Padding="22,16,22,14">

                        <VerticalStackLayout Grid.Column="0"
                                             Spacing="2"
                                             HorizontalOptions="Center">
                            <Label x:Name="EventsAttendedLabel"
                                   Text="0"
                                   FontSize="18"
                                   FontAttributes="Bold"
                                   TextColor="#222"
                                   HorizontalOptions="Center"
                                   HorizontalTextAlignment="Center" />
                            <Label Text="Events attended"
                                   FontSize="13"
                                   TextColor="#777"
                                   HorizontalOptions="Center"
                                   HorizontalTextAlignment="Center" />
                        </VerticalStackLayout>

                        <VerticalStackLayout Grid.Column="1"
                                             Spacing="2"
                                             HorizontalOptions="Center">
                            <Label x:Name="ConnectionsLabel"
                                   Text="0"
                                   FontSize="18"
                                   FontAttributes="Bold"
                                   TextColor="#222"
                                   HorizontalOptions="Center"
                                   HorizontalTextAlignment="Center" />
                            <Label Text="Connections"
                                   FontSize="13"
                                   TextColor="#777"
                                   HorizontalOptions="Center"
                                   HorizontalTextAlignment="Center" />
                        </VerticalStackLayout>

                        <VerticalStackLayout Grid.Column="2"
                                             Spacing="2"
                                             HorizontalOptions="Center">
                            <Label x:Name="RatingLabel"
                                   Text="0.0/5"
                                   FontSize="18"
                                   FontAttributes="Bold"
                                   TextColor="#222"
                                   HorizontalOptions="Center"
                                   HorizontalTextAlignment="Center" />
                            <Label Text="☆☆☆☆☆"
                                   FontSize="16"
                                   TextColor="Black"
                                   HorizontalOptions="Center"
                                   HorizontalTextAlignment="Center" />
                        </VerticalStackLayout>
                    </Grid>

                    <Grid ColumnDefinitions="*,*"
                          ColumnSpacing="18"
                          Padding="18,0,18,16">

                        <Button Grid.Column="0"
                                Text="Edit Profile"
                                Clicked="OnEditProfileClicked"
                                HeightRequest="42"
                                CornerRadius="18"
                                BackgroundColor="#DCE4F5"
                                TextColor="#444"
                                FontSize="15" />

                        <Button Grid.Column="1"
                                Text="Settings"
                                Clicked="OnSettingsClicked"
                                HeightRequest="42"
                                CornerRadius="18"
                                BackgroundColor="#F3F1EA"
                                TextColor="#444"
                                FontSize="15" />
                    </Grid>
                </VerticalStackLayout>
            </Frame>

            <Grid ColumnDefinitions="*,*"
                  ColumnSpacing="12"
                  Margin="28,14,28,0">

                <Button x:Name="PostsTabButton"
                        Grid.Column="0"
                        Text="Posts"
                        Clicked="OnPostsTabClicked"
                        HeightRequest="40"
                        CornerRadius="18"
                        BackgroundColor="#DCE4F5"
                        TextColor="#333"
                        FontSize="15" />

                <Button x:Name="PastActivitiesTabButton"
                        Grid.Column="1"
                        Text="Past activities"
                        Clicked="OnPastActivitiesTabClicked"
                        HeightRequest="40"
                        CornerRadius="18"
                        BackgroundColor="#F3F1EA"
                        TextColor="#333"
                        FontSize="15" />
            </Grid>

            <VerticalStackLayout x:Name="PostsSection" Margin="18,16,18,20">

                <CollectionView x:Name="UserPostsList"
                                SelectionMode="None">

                    <CollectionView.EmptyView>
                        <Label Text="No posts yet"
                               HorizontalOptions="Center"
                               TextColor="#777"
                               Margin="0,20"/>
                    </CollectionView.EmptyView>

                    <CollectionView.ItemTemplate>
                        <DataTemplate>
                            <Frame Padding="14"
                                   CornerRadius="20"
                                   BackgroundColor="White"
                                   HasShadow="True">

                                <VerticalStackLayout Spacing="8">
                                    <Label Text="{Binding Caption}"
                                           FontSize="14"
                                           TextColor="#333"/>

                                    <Image Source="{Binding ImageUrl}"
                                           HeightRequest="200"
                                           Aspect="AspectFill"/>
                                </VerticalStackLayout>

                            </Frame>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>

                </CollectionView>

            </VerticalStackLayout>

            <VerticalStackLayout x:Name="PastActivitiesSection"
                                 IsVisible="False"
                                 Margin="18,16,18,20">
                <Label Text="No activities yet"
                       HorizontalOptions="Center"
                       TextColor="#777"/>
            </VerticalStackLayout>

        </VerticalStackLayout>
    </Grid>
</ContentPage>