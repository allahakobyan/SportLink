<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="SportLink.Mobile.Pages.Search.SearchPage"
             BackgroundColor="#F7F8FC"
             Title="Search">

    <ScrollView>
        <VerticalStackLayout Padding="20,20,20,30" Spacing="18">

            <!-- top bar -->
            <Grid ColumnDefinitions="*,Auto"
                  Padding="0,8,0,0">

                <Label Text="SportLink"
                       FontSize="22"
                       FontAttributes="Bold"
                       TextColor="#111"
                       VerticalOptions="Center" />

                <Button Grid.Column="1"
                        Text="⋯"
                        BackgroundColor="Transparent"
                        TextColor="#222"
                        FontSize="22"
                        Padding="0"
                        WidthRequest="40"
                        HeightRequest="40" />
            </Grid>

            <BoxView HeightRequest="1"
                     Color="#D9DDE7"
                     Margin="-20,0,-20,0" />

            <!-- search -->
            <Frame CornerRadius="18"
                   Padding="12,8"
                   BackgroundColor="White"
                   BorderColor="#E6D6D6"
                   HasShadow="True">

                <Grid ColumnDefinitions="Auto,*"
                      ColumnSpacing="10">
                    <Label Text="🔍"
                           FontSize="18"
                           VerticalOptions="Center" />

                    <Entry x:Name="SearchEntry"
                           Grid.Column="1"
                           Placeholder="yoga class"
                           PlaceholderColor="#9A9A9A"
                           TextColor="#111"
                           BackgroundColor="Transparent"
                           TextChanged="OnSearchTextChanged" />
                </Grid>
            </Frame>

            <!-- featured event -->
            <Frame CornerRadius="20"
                   Padding="16"
                   BackgroundColor="White"
                   BorderColor="#E6D6D6"
                   HasShadow="True">

                <VerticalStackLayout Spacing="10">
                    <Grid ColumnDefinitions="*,Auto"
                          ColumnSpacing="10">

                        <Label Text="Tiffany’s Yoga Class"
                               FontSize="20"
                               FontAttributes="Bold"
                               TextColor="#333"
                               VerticalOptions="Start" />

                        <VerticalStackLayout Grid.Column="1"
                                             Spacing="2"
                                             HorizontalOptions="End">
                            <Label Text="2 places left"
                                   FontSize="12"
                                   TextColor="#555"
                                   HorizontalTextAlignment="End" />
                            <Label Text="Paid event: 15$"
                                   FontSize="12"
                                   TextColor="#555"
                                   HorizontalTextAlignment="End" />
                        </VerticalStackLayout>
                    </Grid>

                    <Grid ColumnDefinitions="*,Auto"
                          RowDefinitions="Auto,Auto"
                          ColumnSpacing="10"
                          RowSpacing="8">

                        <HorizontalStackLayout Grid.Row="0"
                                               Grid.Column="0"
                                               Spacing="8">
                            <Label Text="📅"
                                   FontSize="17" />
                            <Label Text="Sunday, April 20"
                                   FontSize="14"
                                   TextColor="#666"
                                   VerticalOptions="Center" />
                        </HorizontalStackLayout>

                        <Button Grid.RowSpan="2"
                                Grid.Column="1"
                                Text="See details"
                                Clicked="OnSeeDetailsClicked"
                                HeightRequest="38"
                                WidthRequest="110"
                                CornerRadius="16"
                                BackgroundColor="#DFF3E7"
                                TextColor="#5A7D67"
                                FontSize="13" />

                        <HorizontalStackLayout Grid.Row="1"
                                               Grid.Column="0"
                                               Spacing="8">
                            <Label Text="🕒"
                                   FontSize="17" />
                            <Label Text="10:00, Yoga Studio, st. Flowers"
                                   FontSize="14"
                                   TextColor="#666"
                                   VerticalOptions="Center" />
                        </HorizontalStackLayout>
                    </Grid>
                </VerticalStackLayout>
            </Frame>

            <BoxView HeightRequest="1"
                     Color="#D9DDE7"
                     Margin="-20,0,-20,0" />

            <!-- suggestions title -->
            <Label Text="Suggestions"
                   FontSize="20"
                   FontAttributes="Bold"
                   TextColor="#333" />

            <!-- suggestions list -->
            <CollectionView x:Name="SuggestionsList"
                            SelectionMode="None"
                            HeightRequest="520">
                <CollectionView.ItemTemplate>
                    <DataTemplate>
                        <Frame Padding="14"
                               Margin="0,0,0,14"
                               BackgroundColor="White"
                               CornerRadius="20"
                               HasShadow="True">

                            <Frame.GestureRecognizers>
                                <TapGestureRecognizer Tapped="OnSuggestionTapped" />
                            </Frame.GestureRecognizers>

                            <Grid ColumnDefinitions="Auto,*,Auto"
                                  ColumnSpacing="12">

                                <!-- initials circle -->
                                <Frame WidthRequest="46"
                                       HeightRequest="46"
                                       CornerRadius="23"
                                       Padding="0"
                                       BackgroundColor="#F4F3FF"
                                       BorderColor="#7A67F8"
                                       HasShadow="False"
                                       VerticalOptions="Center">
                                    <Label Text="{Binding Initial}"
                                           FontSize="18"
                                           FontAttributes="Bold"
                                           TextColor="#7A67F8"
                                           HorizontalOptions="Center"
                                           VerticalOptions="Center"
                                           HorizontalTextAlignment="Center"
                                           VerticalTextAlignment="Center" />
                                </Frame>

                                <!-- info -->
                                <VerticalStackLayout Grid.Column="1"
                                                     Spacing="3"
                                                     VerticalOptions="Center">

                                    <HorizontalStackLayout Spacing="8">
                                        <Label Text="{Binding Name}"
                                               FontSize="18"
                                               FontAttributes="Bold"
                                               TextColor="#222"
                                               VerticalOptions="Center" />

                                        <Frame Padding="8,2"
                                               CornerRadius="10"
                                               BackgroundColor="#6F63F6"
                                               HasShadow="False"
                                               VerticalOptions="Center">
                                            <Label Text="VERIFIED"
                                                   FontSize="10"
                                                   FontAttributes="Bold"
                                                   TextColor="White" />
                                        </Frame>
                                    </HorizontalStackLayout>

                                    <Label Text="{Binding Specialty}"
                                           FontSize="13"
                                           TextColor="#777" />
                                </VerticalStackLayout>

                                <!-- rating + button -->
                                <VerticalStackLayout Grid.Column="2"
                                                     Spacing="8"
                                                     HorizontalOptions="End"
                                                     VerticalOptions="Center">

                                    <HorizontalStackLayout Spacing="4"
                                                           HorizontalOptions="End">
                                        <Label Text="★"
                                               FontSize="14"
                                               TextColor="#F5B800" />
                                        <Label Text="{Binding Rating}"
                                               FontSize="14"
                                               FontAttributes="Bold"
                                               TextColor="#444" />
                                    </HorizontalStackLayout>

                                    <Button Text="{Binding ConnectButtonText}"
                                            Clicked="OnConnectClicked"
                                            HeightRequest="34"
                                            WidthRequest="90"
                                            CornerRadius="16"
                                            BackgroundColor="#6F63F6"
                                            TextColor="White"
                                            FontSize="13" />
                                </VerticalStackLayout>

                            </Grid>
                        </Frame>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>