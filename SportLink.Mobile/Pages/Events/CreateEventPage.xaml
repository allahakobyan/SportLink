<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="SportLink.Mobile.Pages.Events.CreateEventPage"
             BackgroundColor="#F7F8FC">

    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="15">

            <Label Text="Create Event"
                   FontSize="26"
                   FontAttributes="Bold"
                   TextColor="Black"/>

            <Entry x:Name="TitleEntry"
                   Placeholder="Event title" />

            <DatePicker x:Name="DatePicker" />
            <TimePicker x:Name="TimePickerControl" Format="HH:mm"/>

            <Editor x:Name="DescriptionEditor"
                    Placeholder="Event description"
                    HeightRequest="100"/>

            <Entry x:Name="MaxParticipantsEntry"
                   Placeholder="Maximum participants"
                   Keyboard="Numeric" />

            <!-- PAID TOGGLE -->
            <HorizontalStackLayout Spacing="10">
                <Label Text="Paid event"
                       VerticalOptions="Center"/>
                <Switch x:Name="PaidSwitch"
                        Toggled="OnPaidToggled"/>
            </HorizontalStackLayout>

            <!-- PRICE FIELD -->
            <Entry x:Name="PriceEntry"
                   Placeholder="Enter price"
                   Keyboard="Numeric"
                   IsVisible="False"/>

            <Button Text="Create Event"
                    Clicked="OnCreateEventClicked"
                    BackgroundColor="#6A5AE0"
                    TextColor="White"
                    CornerRadius="10"
                    HeightRequest="50"/>

        </VerticalStackLayout>
    </ScrollView>

</ContentPage>