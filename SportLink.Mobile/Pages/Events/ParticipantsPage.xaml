<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="SportLink.Mobile.Pages.Events.ParticipantsPage"
             BackgroundColor="#F7F8FC">

    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="20">

            <Label Text="Participants"
                   FontSize="28"
                   FontAttributes="Bold"
                   TextColor="Black" />

            <CollectionView x:Name="ParticipantsList">
                <CollectionView.ItemTemplate>
                    <DataTemplate>
                        <Frame Padding="15"
                               Margin="0,5"
                               BackgroundColor="White"
                               CornerRadius="16">
                            <VerticalStackLayout>
                                <Label Text="{Binding}"
                                       FontSize="16"
                                       FontAttributes="Bold"
                                       TextColor="Black" />
                            </VerticalStackLayout>
                        </Frame>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>

        </VerticalStackLayout>
    </ScrollView>

</ContentPage>